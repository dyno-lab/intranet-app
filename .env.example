# Example environment variables. Copy to .env and fill local values.
# Do not commit real secrets or tokens.

APP_NAME=IntranetApp
ENV=dev
SECRET_KEY=replace-with-a-long-random-secret

DB_SERVER=localhost\\SQLEXPRESS
DB_NAME=IntranetApp
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_CERT=no

AUTOMATION_API_KEY=replace-with-automation-token
WKHTMLTOPDF_PATH=
