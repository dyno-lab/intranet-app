	column 'Rango Edad Orden' =
			SWITCH(
			    TRUE(),
			    ISBLANK('bi_dim_participant'[edad_actual]), 99,
			    'bi_dim_participant'[edad_actual] <= 12, 1,
			    'bi_dim_participant'[edad_actual] <= 18, 2,
			    'bi_dim_participant'[edad_actual] <= 59, 3,
			    4
			)
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 7c11d9b0-93a5-4da4-96c9-c9af45f68f7e
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Rango Edad' =
			SWITCH(
			    TRUE(),
			    ISBLANK('bi_dim_participant'[edad_actual]), "Sin edad",
			    'bi_dim_participant'[edad_actual] <= 12, "5-12",
			    'bi_dim_participant'[edad_actual] <= 18, "13-18",
			    'bi_dim_participant'[edad_actual] <= 59, "19-59",
			    "60+"
			)
		dataType: string
		lineageTag: 4067360d-f14e-4a4a-bb26-db17c4c8e17d
		summarizeBy: none
		sortByColumn: 'Rango Edad Orden'

		annotation SummarizationSetBy = Automatic

