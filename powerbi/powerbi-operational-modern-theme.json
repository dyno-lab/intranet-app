{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/theme/v3.1.0/schema.json",
  "name": "Dyno Operational Modern",
  "dataColors": [
    "#1E6FE8",
    "#2536A7",
    "#FF7A2F",
    "#7A2CBF",
    "#16A34A",
    "#FBBF24",
    "#EF4444",
    "#0F766E",
    "#EC4899",
    "#64748B"
  ],
  "background": "#F5F7FB",
  "foreground": "#0F172A",
  "tableAccent": "#1E6FE8",
  "good": "#16A34A",
  "neutral": "#FBBF24",
  "bad": "#EF4444",
  "maximum": "#1E3A8A",
  "minimum": "#E2E8F0",
  "center": "#94A3B8",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "color": { "solid": { "color": "#0F172A" } },
            "alignment": "left"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E5E7EB" } },
            "radius": 14
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#CBD5E1" } },
            "blur": 10,
            "angle": 90,
            "distance": 2,
            "opacity": 0.22
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "transparency": 100
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#334155" } }
          }
        ],
        "items": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#DDE4EE" } },
            "radius": 12
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontSize": 24,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#475569" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ]
      }
    },
    "clusteredColumnChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#1E6FE8" } }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "clusteredBarChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#1E6FE8" } }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#2536A7" } }
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "matrix": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E2E8F0" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E2E8F0" } },
            "outlineColor": { "solid": { "color": "#CBD5E1" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#0F172A" } },
            "backColor": { "solid": { "color": "#F8FAFC" } }
          }
        ],
        "rowHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#334155" } }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ]
      }
    }
  }
}
