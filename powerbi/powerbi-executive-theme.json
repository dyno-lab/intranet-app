{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/theme/v3.1.0/schema.json",
  "name": "Dyno Executive Dashboard",
  "dataColors": [
    "#1677FF",
    "#22C55E",
    "#FBBF24",
    "#EF4444",
    "#1E3A8A",
    "#0EA5E9",
    "#8B5CF6",
    "#F97316",
    "#14B8A6",
    "#64748B"
  ],
  "background": "#F5F7FB",
  "foreground": "#0F172A",
  "tableAccent": "#1677FF",
  "good": "#22C55E",
  "neutral": "#FBBF24",
  "bad": "#EF4444",
  "maximum": "#1E3A8A",
  "minimum": "#E2E8F0",
  "center": "#94A3B8",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "color": { "solid": { "color": "#0F172A" } },
            "alignment": "left"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E5E7EB" } },
            "radius": 12
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#D9E2F1" } },
            "blur": 8,
            "angle": 90,
            "distance": 2,
            "opacity": 0.18
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "transparency": 100
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "color": { "solid": { "color": "#334155" } }
          }
        ],
        "items": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#CBD5E1" } },
            "radius": 10
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#1677FF" } },
            "fontSize": 24,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#64748B" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#1677FF" } }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#1E3A8A" } }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#1677FF" } }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } }
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#475569" } }
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "matrix": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E2E8F0" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E2E8F0" } },
            "outlineColor": { "solid": { "color": "#CBD5E1" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#0F172A" } },
            "backColor": { "solid": { "color": "#F8FAFC" } }
          }
        ],
        "rowHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#334155" } }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ]
      }
    }
  }
}
